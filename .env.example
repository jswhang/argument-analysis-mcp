# Argument Analysis MCP Server — configuration
# Copy to .env and adjust as needed, or set as environment variables.

# Directory where SQLite databases and ChromaDB data are stored
AA_MCP_DATA_DIR=~/.aa-mcp/data

# RAG vector backend: chroma | sqlite-vec | lancedb
AA_MCP_RAG__BACKEND=chroma

# Embedding model (sentence-transformers compatible)
AA_MCP_EMBEDDER__MODEL=sentence-transformers/all-MiniLM-L6-v2
# Device: cpu | cuda | mps
AA_MCP_EMBEDDER__DEVICE=cpu

# Sampling (LLM callback) settings
AA_MCP_SAMPLING__ENABLED=true
AA_MCP_SAMPLING__MAX_TOKENS=2048
AA_MCP_SAMPLING__TOP_K_RETRIEVAL=10
AA_MCP_SAMPLING__TOP_K_FINAL=5

# Logging
AA_MCP_LOG_LEVEL=INFO
